{
  "name": "atlas-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:portal": "turbo dev --filter=@atlas/portal",
    "dev:hermes": "turbo dev --filter=@atlas/hermes",
    "dev:zwei": "turbo dev --filter=@atlas/zwei",
    "dev:chaos": "turbo dev --filter=@atlas/chaos",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,scss,css,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,scss,css,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@heliannuuthus/aegis-ts": "^1.3.1"
  }
}
